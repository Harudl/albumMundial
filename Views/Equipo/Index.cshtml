@model IEnumerable<albumMundial.Models.Equipo>
@{
    ViewData["Title"] = "Equipos";
}
<style>
    :root {
        --card-bg: rgba(22, 24, 31, 0.85);
        --border-color: rgba(38, 41, 54, 0.7);
        --accent-yellow: #ffc107;
        --accent-purple: #a855f7;
        --text-secondary: #cbd5e1;
    }

    body {
        background: linear-gradient(180deg, rgba(13, 14, 18, 0.4) 0%, rgba(13, 14, 18, 0.9) 100%), url('/images/home_imagen.png') no-repeat center center fixed;
        background-size: cover;
    }

    .sports-widget {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        backdrop-filter: blur(8px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .widget-title {
        font-size: 0.85rem;
        letter-spacing: 1px;
        color: #fff;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .equipo-card {
        background: linear-gradient(180deg, rgba(30, 32, 41, 0.5) 0%, rgba(15, 16, 22, 0.95) 100%);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.25rem;
        transition: transform 0.2s ease, border-color 0.2s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

    .equipo-card-bg-img {
        position: absolute;
        top: 0;
        right: 0;
        width: 60%;
        height: 100%;
        object-fit: cover;
        opacity: 0.15;
        mask-image: linear-gradient(to left, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 100%);
        -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 100%);
        pointer-events: none;
        z-index: 1;
    }

    .equipo-card-content {
        position: relative;
        z-index: 2;
    }

    .equipo-card:hover {
        border-color: var(--accent-yellow);
        transform: translateY(-4px);
    }

    .equipo-logo-sm {
        width: 40px;
        height: 40px;
        object-fit: contain;
        background: rgba(255,255,255,0.07);
        border-radius: 8px;
        padding: 4px;
        border: 1px solid rgba(255,255,255,0.1);
        flex-shrink: 0;
    }

    .form-dark-input {
        background-color: rgba(13, 14, 18, 0.6) !important;
        border: 1px solid var(--border-color) !important;
        color: #fff !important;
    }

        .form-dark-input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .form-dark-input:focus {
            border-color: var(--accent-yellow) !important;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25) !important;
        }

    .btn-action-view {
        color: #38bdf8;
        border-color: rgba(56, 189, 248, 0.4);
        background: transparent;
    }

        .btn-action-view:hover {
            background-color: #38bdf8;
            color: #000;
        }

    .btn-action-edit {
        color: #fbbf24;
        border-color: rgba(251, 191, 36, 0.4);
        background: transparent;
    }

        .btn-action-edit:hover {
            background-color: #fbbf24;
            color: #000;
        }

    .btn-action-delete {
        color: #f87171;
        border-color: rgba(248, 113, 113, 0.4);
        background: transparent;
    }

        .btn-action-delete:hover {
            background-color: #f87171;
            color: #fff;
        }

    .badge-grupo {
        background: rgba(168, 85, 247, 0.15);
        border: 1px solid rgba(168, 85, 247, 0.4);
        color: #c084fc;
        font-size: 0.7rem;
        padding: 3px 8px;
        border-radius: 6px;
        font-weight: 700;
        letter-spacing: 1px;
        white-space: nowrap;
        flex-shrink: 0;
    }
</style>

<div class="container mt-4">
    <div class="sports-widget">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div class="widget-title mb-0">
                <i data-lucide="shield" class="text-warning" style="width: 20px; height: 20px;"></i>
                <span class="fs-5 text-white" style="text-transform: none; letter-spacing: normal;">Gestión de Equipos</span>
            </div>
            <a asp-action="Create" class="btn btn-warning btn-sm fw-bold px-3 py-2 rounded-2 shadow">
                + Nuevo Equipo
            </a>
        </div>

        <form method="get" asp-action="Index" class="row g-2 mb-4">
            <div class="col-md-7 col-sm-12">
                <input type="text" name="buscar" value="@ViewBag.Buscar"
                       class="form-control form-dark-input"
                       placeholder="Buscar por nombre o país..." />
            </div>
            <div class="col-md-5 col-sm-12 d-flex gap-2">
                <button type="submit" class="btn btn-outline-light w-100 fw-semibold border-secondary">
                    <i data-lucide="search" class="d-inline-block me-1" style="width: 14px; height: 14px;"></i> Buscar
                </button>
                <a asp-action="Index" class="btn btn-secondary w-100 opacity-75">Limpiar</a>
            </div>
        </form>

        <hr class="border-secondary opacity-25 mb-4">

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="equipo-card shadow">

                            @if (!string.IsNullOrEmpty(item.LogoUrl))
                            {
                                <img src="@item.LogoUrl" class="equipo-card-bg-img" alt="Logo @item.Nombre" />
                            }

                            <div class="equipo-card-content">

                                <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                    <div class="d-flex align-items-center gap-2 overflow-hidden">
                                        @if (!string.IsNullOrEmpty(item.LogoUrl))
                                        {
                                            <img src="@item.LogoUrl" class="equipo-logo-sm" alt="Logo @item.Nombre" />
                                        }
                                        <h5 class="text-white fw-bold mb-0 text-truncate"
                                            style="text-shadow: 0 2px 4px rgba(0,0,0,0.8);">
                                            @item.Nombre
                                        </h5>
                                    </div>
                                    <span class="badge-grupo text-uppercase">
                                        GRUPO @item.GrupoMundialista
                                    </span>
                                </div>

                                <p class="mb-3 small fw-semibold" style="color: var(--text-secondary);">
                                    <i data-lucide="map-pin" class="d-inline-block me-1 text-info"
                                       style="width: 13px; height: 13px;"></i>
                                    País: <span class="text-white">@(item.Pais?.Nombre ?? "Sin país")</span>
                                </p>

                                <div class="p-2 rounded mb-3"
                                     style="background-color: rgba(10, 11, 14, 0.75); border: 1px solid rgba(255,255,255,0.05);">
                                    <div class="d-flex justify-content-between small mb-1">
                                        <span style="color: var(--text-secondary);">Director Técnico:</span>
                                        <span class="fw-bold text-white text-truncate ms-2">
                                            @(string.IsNullOrEmpty(item.DirectorTecnico) ? "N/A" : item.DirectorTecnico)
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between small">
                                        <span style="color: var(--text-secondary);">Año Fundación:</span>
                                        <span class="fw-bold" style="color: #c084fc;">
                                            @(item.AnioFundacion > 0 ? item.AnioFundacion.ToString() : "N/A")
                                        </span>
                                    </div>
                                </div>

                            </div>

                            <div class="d-flex gap-2 mt-auto pt-2 border-top border-secondary border-opacity-25"
                                 style="position: relative; z-index: 2;">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-action-view btn-sm w-100 py-1 fw-bold">
                                    Ver
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-action-edit btn-sm w-100 py-1 fw-bold">
                                    Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-action-delete btn-sm w-100 py-1 fw-bold">
                                    Eliminar
                                </a>
                            </div>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="mb-0 fs-5 text-white-50">No se encontraron equipos registrados.</p>
                </div>
            }
        </div>

    </div>
</div>