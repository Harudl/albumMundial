@model albumMundial.Models.Album

@{
    ViewData["Title"] = "Editar Álbum";
}

<style>
    :root {
        --card-bg: rgba(22,24,31,.85);
        --border-color: rgba(38,41,54,.7);
        --accent-yellow: #ffc107;
        --text-secondary: #cbd5e1;
    }

    body {
        background: linear-gradient(180deg, rgba(13,14,18,.4) 0%, rgba(13,14,18,.9) 100%), url('/images/home_imagen.png') no-repeat center center fixed;
        background-size: cover;
    }

    .card-dashboard-dark {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 18px;
        backdrop-filter: blur(12px);
        box-shadow: 0 10px 30px rgba(0,0,0,.5);
    }

    .form-label {
        color: var(--text-secondary);
        font-size: .75rem;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: .8px;
    }

    .form-control-dark {
        background: rgba(13,14,18,.6) !important;
        border: 1px solid var(--border-color) !important;
        color: white !important;
    }

        .form-control-dark:focus {
            border-color: var(--accent-yellow) !important;
            box-shadow: 0 0 0 .2rem rgba(255,193,7,.15) !important;
        }

        .form-control-dark option {
            background: #16181f;
            color: white;
        }

    .preview-container {
        width: 100%;
        max-width: 220px;
        aspect-ratio: 3 / 4;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-color);
        background: rgba(13,14,18,.5);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .preview-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .file-dropzone-dark {
        position: relative;
        border: 2px dashed rgba(255,255,255,.2);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        background: rgba(13,14,18,.4);
    }

        .file-dropzone-dark input[type=file] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
        }

    .btn-action-yellow {
        background: var(--accent-yellow);
        color: black;
        font-weight: 700;
        border: none;
    }

        .btn-action-yellow:hover {
            background: #e0a800;
        }

    .link-back {
        color: var(--text-secondary);
        text-decoration: none;
    }

        .link-back:hover {
            color: var(--accent-yellow);
        }
</style>

<div class="container py-5">

    <div class="mb-4">
        <a asp-action="Index" class="link-back">
            ← Volver a Álbumes
        </a>
    </div>

    <div class="card card-dashboard-dark">
        <div class="p-4 text-center">
            <h3 class="text-white fw-bold">Editar Álbum</h3>
            <p class="mb-0 text-secondary">
                Modifica la información y portada del álbum.
            </p>
            <hr class="border-secondary opacity-25">
        </div>

        <div class="card-body px-4 pb-5">

            <form asp-action="Edit" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImagenUrl" />

                <div class="row g-4">

                    <div class="col-md-5 d-flex flex-column align-items-center border-end border-secondary border-opacity-25">

                        <label class="form-label mb-2">
                            Portada Actual
                        </label>

                        <div class="preview-container mb-3">

                            @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                            {
                                <img src="@Model.ImagenUrl"
                                     id="img-preview"
                                     class="preview-img" />
                            }
                            else
                            {
                                <span class="text-white-50">
                                    Sin imagen
                                </span>
                            }

                        </div>

                        <div class="file-dropzone-dark w-100">

                            <h6 class="text-white fw-bold">
                                Reemplazar portada
                            </h6>

                            <small class="text-secondary">
                                JPG, PNG o WEBP
                            </small>

                            <input type="file"
                                   name="nuevaImagenAlbum"
                                   id="nuevaImagenAlbum"
                                   accept="image/*" />
                        </div>

                        <div id="file-name-preview"
                             class="text-warning small mt-2">
                        </div>

                    </div>

                    <div class="col-md-7">

                        <div class="mb-3">
                            <label asp-for="Nombre"
                                   class="form-label"></label>

                            <input asp-for="Nombre"
                                   class="form-control form-control-dark" />

                            <span asp-validation-for="Nombre"
                                  class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Anio"
                                   class="form-label"></label>

                            <input asp-for="Anio"
                                   class="form-control form-control-dark" />

                            <span asp-validation-for="Anio"
                                  class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CantidadCromos"
                                   class="form-label"></label>

                            <input asp-for="CantidadCromos"
                                   class="form-control form-control-dark" />

                            <span asp-validation-for="CantidadCromos"
                                  class="text-danger"></span>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input asp-for="EdicionEspecial"
                                   class="form-check-input"
                                   style="transform:scale(1.3);" />

                            <label asp-for="EdicionEspecial"
                                   class="form-check-label text-white ms-2">
                            </label>
                        </div>

                        <div class="d-grid">
                            <button type="submit"
                                    class="btn btn-action-yellow py-2">
                                Guardar Cambios
                            </button>
                        </div>

                    </div>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById('nuevaImagenAlbum')
            .addEventListener('change', function(e){

            let file = e.target.files[0];

            if(file){

                document.getElementById('file-name-preview')
                    .innerText = "✓ " + file.name;

                const reader = new FileReader();

                reader.onload = function(ev){

                    let img =
                        document.getElementById('img-preview');

                    if(img){
                        img.src = ev.target.result;
                    }
                };

                reader.readAsDataURL(file);
            }
        });
    </script>
}