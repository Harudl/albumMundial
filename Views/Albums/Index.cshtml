@model IEnumerable<albumMundial.Models.Album>

@{
    ViewData["Title"] = "Álbumes";
}

<style>
    :root {
        --card-bg: rgba(22, 24, 31, 0.85);
        --border-color: rgba(38, 41, 54, 0.7);
        --accent-yellow: #ffc107;
        --text-secondary: #cbd5e1;
    }

    body {
        background: linear-gradient( 180deg, rgba(13,14,18,0.4) 0%, rgba(13,14,18,0.9) 100% ), url('/images/home_imagen.png') no-repeat center center fixed;
        background-size: cover;
    }

    .card-dashboard-dark {
        border: 1px solid var(--border-color);
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        background-color: var(--card-bg);
        backdrop-filter: blur(12px);
    }

    .form-label {
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: .8px;
    }

    .form-control-dark {
        background-color: rgba(13,14,18,0.6) !important;
        border: 1px solid var(--border-color) !important;
        color: #fff !important;
        border-radius: 8px;
        padding: 10px 14px;
    }

        .form-control-dark:focus {
            background-color: rgba(13,14,18,0.8) !important;
            border-color: var(--accent-yellow) !important;
            box-shadow: 0 0 0 3px rgba(255,193,7,.2) !important;
            color: white !important;
        }

    .preview-container {
        width: 100%;
        max-width: 220px;
        aspect-ratio: 3/4;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-color);
        background-color: rgba(10,11,14,.6);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .preview-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .file-dropzone-dark {
        position: relative;
        border: 2px dashed rgba(255,255,255,.2);
        background-color: rgba(13,14,18,.4);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: all .3s ease;
        cursor: pointer;
    }

        .file-dropzone-dark:hover {
            border-color: var(--accent-yellow);
            background-color: rgba(255,193,7,.05);
        }

        .file-dropzone-dark input[type=file] {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

    .btn-action-yellow {
        background-color: var(--accent-yellow);
        color: #000;
        font-weight: 700;
        text-transform: uppercase;
        border: none;
        border-radius: 8px;
        padding: 12px;
    }

        .btn-action-yellow:hover {
            background-color: #e0a800;
            color: #000;
        }

    .link-back {
        color: var(--text-secondary);
        font-weight: 600;
    }

        .link-back:hover {
            color: var(--accent-yellow);
        }

    .form-check-input {
        transform: scale(1.3);
    }
</style>

<div class="container mt-4">
    <div class="sports-widget">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

            <div class="widget-title">
                <i data-lucide="book-open"
                   class="text-warning"
                   style="width:20px;height:20px;"></i>

                <span class="fs-5 text-white"
                      style="text-transform:none;letter-spacing:normal;font-weight:700;">
                    Colección de Álbumes
                </span>
            </div>

            <a asp-action="Create"
               class="btn btn-warning btn-sm fw-bold px-3 py-2 rounded-2 shadow">
                + Registrar Álbum
            </a>

        </div>

        <form asp-action="Index" method="get">

            <div class="form-check form-switch mb-4">

                <input class="form-check-input"
                       type="checkbox"
                       id="soloEspeciales"
                       name="soloEspeciales"
                       value="true"
                @(Context.Request.Query["soloEspeciales"] == "true" ? "checked" : "")
                       onchange="this.form.submit()" />

                <label class="form-check-label text-white"
                       for="soloEspeciales">
                    Mostrar solo ediciones especiales
                </label>

            </div>

        </form>

        <hr class="border-secondary opacity-25 mb-4">

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            @foreach (var item in Model)
            {
                string albumClase = item.EdicionEspecial
                    ? "cromo-especial"
                    : "cromo-estandar";

                <div class="col">

                    <div class="cromo-card h-100 @albumClase">

                        <div class="cromo-img-container">

                            @if (!string.IsNullOrEmpty(item.FotoUrl))
                            {
                                <img src="@item.FotoUrl"
                                     class="cromo-img"
                                     alt="@item.Nombre" />
                            }
                            else
                            {
                                <div class="text-center opacity-50">
                                    <i data-lucide="book-open"
                                       style="width:90px;height:90px;color:#ffc107;">
                                    </i>
                                </div>
                            }

                            <span class="badge-number">
                                @item.Anio
                            </span>

                        </div>

                        <div class="card-body p-3">

                            <div class="d-flex justify-content-between align-items-center mb-2">

                                @if (item.EdicionEspecial)
                                {
                                    <span class="badge badge-edicion px-2 py-1 rounded">
                                        ESPECIAL
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        ESTÁNDAR
                                    </span>
                                }

                                <span class="fw-bold text-warning">
                                    @item.CantidadCromos
                                </span>

                            </div>

                            <h5 class="fw-bold text-white mb-2 text-truncate">
                                @item.Nombre
                            </h5>

                            <p class="mb-2 text-info small d-flex align-items-center gap-1">
                                <i data-lucide="calendar"
                                   style="width:14px;height:14px;"></i>

                                Año @item.Anio
                            </p>

                            <p class="mb-0 text-white-50 small d-flex align-items-center gap-1">
                                <i data-lucide="layers"
                                   style="width:14px;height:14px;"></i>

                                @item.Cromos.Count cromos registrados
                            </p>

                        </div>

                        <div class="btn-action-panel p-2 d-flex justify-content-around align-items-center">

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="action-icon edit-btn text-decoration-none small d-flex align-items-center gap-1">

                                <i data-lucide="pencil"
                                   style="width:15px;height:15px;"></i>

                                <span style="font-size:0.75rem;">
                                    Editar
                                </span>

                            </a>

                            <div class="text-white-50 opacity-25">|</div>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="action-icon text-decoration-none small d-flex align-items-center gap-1">

                                <i data-lucide="eye"
                                   style="width:15px;height:15px;"></i>

                                <span style="font-size:0.75rem;">
                                    Ver
                                </span>

                            </a>

                            <div class="text-white-50 opacity-25">|</div>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="action-icon delete-btn text-decoration-none small d-flex align-items-center gap-1">

                                <i data-lucide="trash-2"
                                   style="width:15px;height:15px;"></i>

                                <span style="font-size:0.75rem;">
                                    Borrar
                                </span>

                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>
</div>

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    </script>
}