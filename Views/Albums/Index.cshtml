@model IEnumerable<albumMundial.Models.Album>

@{
    ViewData["Title"] = "Álbumes";
}

<style>
    :root {
        --card-bg: rgba(22, 24, 31, 0.85);
        --border-color: rgba(38, 41, 54, 0.7);
        --accent-yellow: #ffc107;
        --accent-purple: #a855f7;
        --text-secondary: #cbd5e1;
    }

    /* 🟢 FONDO GLOBAL CON CAPA OSCURA */
    body {
        background: linear-gradient(180deg, rgba(13, 14, 18, 0.4) 0%, rgba(13, 14, 18, 0.9) 100%), url('/images/home_imagen.png') no-repeat center center fixed;
        background-size: cover;
    }

    /* Contenedor Principal Estilo Widget */
    .sports-widget {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        backdrop-filter: blur(8px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .widget-title {
        font-size: 0.85rem;
        text-uppercase: uppercase;
        letter-spacing: 1px;
        color: #fff;
        font-weight: 700;
        margin-bottom: 0rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* ========================================================
               ESTRUCTURA PREMIUM DEL CROMO DIGITAL
               ======================================================== */
    .cromo-card {
        background: rgba(15, 17, 23, 0.85);
        border-radius: 14px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

        .cromo-card:hover {
            transform: translateY(-8px) scale(1.02);
        }

    /* Contenedor de la Imagen */
    .cromo-img-container {
        position: relative;
        width: 100%;
        aspect-ratio: 3 / 4;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background-color: rgba(10, 11, 14, 0.5);
    }

    .cromo-img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Cambiado a cover para un look dinámico de cromo de fútbol */
        transition: transform 0.5s ease;
    }

    .cromo-card:hover .cromo-img {
        transform: scale(1.08); /* Efecto zoom sutil al pasar el cursor */
    }

    /* Número Flotante Premium */
    .badge-number {
        position: absolute;
        top: 10px;
        left: 10px;
        background-color: rgba(15, 17, 23, 0.9);
        color: #fff;
        border: 1px solid var(--border-color);
        font-weight: 800;
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 0.7rem;
        z-index: 10;
        letter-spacing: 0.5px;
    }

    /* Inputs y Buscador estilizados oscuros */
    .form-dark-input {
        background-color: rgba(13, 14, 18, 0.6) !important;
        border: 1px solid var(--border-color) !important;
        color: #fff !important;
    }

        .form-dark-input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .form-dark-input:focus {
            border-color: var(--accent-yellow) !important;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25) !important;
        }

    /* ========================================================
               MARCOS Y BRILLOS PERSONALIZADOS (NEÓN EFFECTS)
               ======================================================== */

    /* 1. Edición Estándar */
    .cromo-estandar {
        border: 1px solid rgba(255, 255, 255, 0.15);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    }

        .cromo-estandar .badge-edicion {
            background-color: rgba(255, 255, 255, 0.1);
            color: #e2e8f0;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

    /* 2. Edición Oro (Brillo Dorado Gamer) */
    .cromo-oro {
        border: 2px solid #eab308 !important;
        box-shadow: 0 0 15px rgba(234, 179, 8, 0.35);
    }

        .cromo-oro .badge-edicion {
            background: linear-gradient(135deg, #fef08a, #eab308);
            color: #000;
            font-weight: 800;
        }

        .cromo-oro .badge-number {
            border-color: #eab308;
            color: #eab308;
        }

    /* 3. Edición Especial / Leyenda / Shiny (Efecto Energético) */
    .cromo-especial {
        border: 2px solid #c084fc !important;
        box-shadow: 0 0 15px rgba(168, 85, 247, 0.45);
    }

        .cromo-especial .badge-edicion {
            background: linear-gradient(135deg, #a855f7, #6366f1);
            color: #fff;
            font-weight: 800;
        }

        .cromo-especial .badge-number {
            border-color: #c084fc;
            color: #c084fc;
        }

    /* Panel de Acciones Inferior */
    .btn-action-panel {
        background-color: rgba(10, 11, 14, 0.8);
        border-top: 1px solid var(--border-color);
    }

    .action-icon {
        padding: 6px 10px;
        border-radius: 6px;
        color: #94a3b8;
        transition: all 0.2s;
        font-weight: 600;
    }

        .action-icon:hover {
            background-color: rgba(56, 189, 248, 0.15);
            color: #38bdf8;
        }

        .action-icon.edit-btn:hover {
            background-color: rgba(251, 191, 36, 0.15);
            color: #fbbf24;
        }

        .action-icon.delete-btn:hover {
            color: #f87171;
            background-color: rgba(248, 113, 113, 0.15);
        }
</style>
<div class="container mt-4">
    <div class="sports-widget">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

            <div class="widget-title">
                <i data-lucide="book-open"
                   class="text-warning"
                   style="width:20px;height:20px;"></i>

                <span class="fs-5 text-white"
                      style="text-transform:none;letter-spacing:normal;font-weight:700;">
                    Colección de Álbumes
                </span>
            </div>

            <a asp-action="Create"
               class="btn btn-warning btn-sm fw-bold px-3 py-2 rounded-2 shadow">
                + Registrar Álbum
            </a>

        </div>

        <form asp-action="Index" method="get">

            <div class="form-check form-switch mb-4">

                <input class="form-check-input"
                       type="checkbox"
                       id="soloEspeciales"
                       name="soloEspeciales"
                       value="true"
                @(Context.Request.Query["soloEspeciales"] == "true" ? "checked" : "")
                       onchange="this.form.submit()" />

                <label class="form-check-label text-white"
                       for="soloEspeciales">
                    Mostrar solo ediciones especiales
                </label>

            </div>

        </form>

        <hr class="border-secondary opacity-25 mb-4">

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            @foreach (var item in Model)
            {
                string albumClase = item.EdicionEspecial
                    ? "cromo-especial"
                    : "cromo-estandar";

                <div class="col">

                    <div class="cromo-card h-100 @albumClase">

                        <div class="cromo-img-container">

                            @if (!string.IsNullOrEmpty(item.FotoUrl))
                            {
                                <img src="@item.FotoUrl"
                                     class="cromo-img"
                                     alt="@item.Nombre" />
                            }
                            else
                            {
                                <div class="text-center opacity-50">
                                    <i data-lucide="book-open"
                                       style="width:90px;height:90px;color:#ffc107;">
                                    </i>
                                </div>
                            }

                            <span class="badge-number">
                                @item.Anio
                            </span>

                        </div>

                        <div class="card-body p-3">

                            <div class="d-flex justify-content-between align-items-center mb-2">

                                @if (item.EdicionEspecial)
                                {
                                    <span class="badge badge-edicion px-2 py-1 rounded">
                                        ESPECIAL
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        ESTÁNDAR
                                    </span>
                                }

                                <span class="fw-bold text-warning">
                                    @item.CantidadCromos
                                </span>

                            </div>

                            <h5 class="fw-bold text-white mb-2 text-truncate">
                                @item.Nombre
                            </h5>

                            <p class="mb-2 text-info small d-flex align-items-center gap-1">
                                <i data-lucide="calendar"
                                   style="width:14px;height:14px;"></i>

                                Año @item.Anio
                            </p>

                            <p class="mb-0 text-white-50 small d-flex align-items-center gap-1">
                                <i data-lucide="layers"
                                   style="width:14px;height:14px;"></i>

                                @item.Cromos.Count cromos registrados
                            </p>

                        </div>

                        <div class="btn-action-panel p-2 d-flex justify-content-around align-items-center">

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="action-icon edit-btn text-decoration-none small d-flex align-items-center gap-1">

                                <i data-lucide="pencil"
                                   style="width:15px;height:15px;"></i>

                                <span style="font-size:0.75rem;">
                                    Editar
                                </span>

                            </a>

                            <div class="text-white-50 opacity-25">|</div>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="action-icon text-decoration-none small d-flex align-items-center gap-1">

                                <i data-lucide="eye"
                                   style="width:15px;height:15px;"></i>

                                <span style="font-size:0.75rem;">
                                    Ver
                                </span>

                            </a>

                            <div class="text-white-50 opacity-25">|</div>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="action-icon delete-btn text-decoration-none small d-flex align-items-center gap-1">

                                <i data-lucide="trash-2"
                                   style="width:15px;height:15px;"></i>

                                <span style="font-size:0.75rem;">
                                    Borrar
                                </span>

                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>
</div>

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    </script>
}