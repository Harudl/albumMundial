@model IEnumerable<albumMundial.Models.Pais>
@{
    ViewData["Title"] = "Países";
}

<h1>🌍 Países</h1>

<form method="get" asp-action="Index" class="d-flex mb-3">
    <input type="text" name="buscar" value="@ViewBag.Buscar"
           class="form-control me-2" placeholder="Buscar por nombre o continente..." />
    <button type="submit" class="btn btn-primary">Buscar</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Limpiar</a>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">+ Nuevo País</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(m => m.Nombre)</th>
            <th>@Html.DisplayNameFor(m => m.Continente)</th>
            <th>@Html.DisplayNameFor(m => m.CodigoFifa)</th>
            <th>@Html.DisplayNameFor(m => m.RankingFifa)</th>
            <th>Equipo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Continente</td>
                <td>@item.CodigoFifa</td>
                <td>@item.RankingFifa</td>
                <td>@(item.Equipo?.Nombre ?? "Sin equipo")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">Ver</a>
                    <a asp-action="Edit" asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>