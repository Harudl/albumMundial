@model albumMundial.Models.Cromo

@{
    ViewData["Title"] = "Detalles del Cromo";
}

<style>
    :root {
        --card-bg: rgba(22, 24, 31, 0.85);
        --border-color: rgba(38, 41, 54, 0.7);
        --accent-yellow: #ffc107;
        --accent-purple: #a855f7;
        --text-secondary: #cbd5e1;
    }

    /* 🟢 FONDO GLOBAL CON CAPA OSCURA */
    body {
        background: linear-gradient(180deg, rgba(13, 14, 18, 0.4) 0%, rgba(13, 14, 18, 0.9) 100%), url('/images/home_imagen.png') no-repeat center center fixed;
        background-size: cover;
    }

    /* Contenedor Principal con Efecto Glassmorphism */
    .card-details {
        border: 1px solid var(--border-color);
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
        background-color: var(--card-bg);
        backdrop-filter: blur(12px);
        overflow: hidden;
    }

    /* Contenedor del Cromo en Alta Definición */
    .cromo-view-container {
        background-color: rgba(10, 11, 14, 0.6);
        border-radius: 16px;
        width: 100%;
        max-width: 320px;
        aspect-ratio: 3 / 4;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .cromo-view-container:hover {
            transform: scale(1.03) rotate(1deg); /* Ligero giro de cromo de colección */
        }

    .cromo-view-img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Se expande por completo para lucir imponente */
    }

    .badge-view-number {
        position: absolute;
        top: 16px;
        left: 16px;
        background-color: rgba(15, 17, 23, 0.9);
        color: #ffffff;
        border: 1px solid var(--border-color);
        font-weight: 800;
        padding: 5px 12px;
        border-radius: 8px;
        font-size: 0.8rem;
        z-index: 10;
        letter-spacing: 0.5px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }

    /* ========================================================
           MARCOS PRESET Y BRILLOS DE NEÓN PREMIUM (DETALLE)
           ======================================================== */
    .border-view-estandar {
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.5);
    }

    .border-view-oro {
        border: 3px solid #eab308 !important;
        box-shadow: 0 0 25px rgba(234, 179, 8, 0.5);
    }

        .border-view-oro .badge-view-number {
            border-color: #eab308;
            color: #eab308;
        }

    .border-view-especial {
        border: 3px solid #c084fc !important;
        box-shadow: 0 0 25px rgba(168, 85, 247, 0.6);
    }

        .border-view-especial .badge-view-number {
            border-color: #c084fc;
            color: #c084fc;
        }

    /* Detalles de la Ficha Técnica (Zonas Oscuras de Alto Contraste) */
    .info-label {
        font-weight: 700;
        color: var(--text-secondary);
        text-uppercase: uppercase;
        font-size: 0.7rem;
        letter-spacing: 1.2px;
        margin-bottom: 2px;
    }

    .info-value {
        font-size: 1.15rem;
        font-weight: 700;
        color: #ffffff;
    }

    .info-box {
        background-color: rgba(13, 14, 18, 0.6);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 14px 18px;
        transition: all 0.2s ease;
    }

        .info-box:hover {
            background-color: rgba(22, 24, 31, 0.9);
            border-color: rgba(255, 255, 255, 0.15);
        }

    /* Botonera de navegación */
    .btn-edit-action {
        background-color: var(--accent-yellow);
        color: #000;
        font-weight: 700;
        border: none;
        transition: all 0.2s;
    }

        .btn-edit-action:hover {
            background-color: #e0a800;
            color: #000;
            box-shadow: 0 4px 15px rgba(255, 193, 7, 0.4);
        }

    .link-back {
        color: var(--text-secondary);
        font-weight: 600;
        transition: color 0.2s;
    }

        .link-back:hover {
            color: var(--accent-yellow);
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="mb-4">
                <a asp-action="Index" class="text-decoration-none link-back small d-inline-flex align-items-center gap-2" data-ajax="true">
                    <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Volver al Catálogo de Cromos
                </a>
            </div>

            <div class="card card-details p-4 p-sm-5">
                <div class="row g-5 align-items-center">

                    @* 1. SECCIÓN IZQUIERDA: VISUALIZADOR DEL CROMO *@
                    <div class="col-md-5 d-flex justify-content-center">
                        @{
                            string edicionClase = "border-view-estandar";
                            string edicionTexto = Model.Edicion?.ToLower() ?? "";

                            if (edicionTexto.Contains("oro")) edicionClase = "border-view-oro";
                            else if (edicionTexto.Contains("especial") || edicionTexto.Contains("shiny") || edicionTexto.Contains("leyenda")) edicionClase = "border-view-especial";
                        }

                        <div class="cromo-view-container @edicionClase">
                            <span class="badge-view-number">N° @Model.NumeroCromo</span>

                            @if (!string.IsNullOrEmpty(Model.FotoUrl))
                            {
                                <img src="@Model.FotoUrl" class="cromo-view-img" alt="Cromo de @Model.Jugador?.Nombre" />
                            }
                            else
                            {
                                <div class="text-center py-5 opacity-25">
                                    <i data-lucide="user" style="width: 64px; height: 64px;" class="text-white mb-2"></i>
                                    <p class="text-white small mb-0">Sin estampa física</p>
                                </div>
                            }
                        </div>
                    </div>

                    @* 2. SECCIÓN DERECHA: DATOS TÉCNICOS EN ALTO CONTRASTE *@
                    <div class="col-md-7">
                        <div class="mb-4">
                            <span class="badge text-uppercase px-3 py-2 rounded-pill mb-2 fw-extrabold"
                                  style="background-color: @(edicionClase == "border-view-oro" ? "rgba(234, 179, 8, 0.2)" : edicionClase == "border-view-especial" ? "rgba(168, 85, 247, 0.2)" : "rgba(255,255,255,0.1)");
                                color: @(edicionClase == "border-view-oro" ? "#fef08a" : edicionClase == "border-view-especial" ? "#c084fc" : "#e2e8f0");
                                border: 1px solid @(edicionClase == "border-view-oro" ? "#eab308" : edicionClase == "border-view-especial" ? "#a855f7" : "rgba(255,255,255,0.2)");">
                                🏆 Edición @Model.Edicion
                            </span>

                            <h1 class="fw-extrabold text-white m-0 mt-2" style="font-size: 2.2rem; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
                                @(Model.Jugador?.Nombre ?? "Crack Desconocido")
                            </h1>
                            <p class="small mt-1" style="color: var(--text-secondary);">Especificaciones oficiales en el Álbum Digital Mundial.</p>
                        </div>

                        <hr class="border-secondary opacity-25 my-4" />

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <div class="info-box d-flex align-items-center gap-3">
                                    <div class="text-success bg-success bg-opacity-20 p-2.5 rounded-3 border border-success border-opacity-25">
                                        <i data-lucide="dollar-sign" style="width: 20px; height: 20px;"></i>
                                    </div>
                                    <div>
                                        <div class="info-label">Valor de Mercado</div>
                                        <div class="info-value text-success" style="font-size: 1.3rem;">$@string.Format("{0:N2}", Model.ValorMercado)</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="info-box d-flex align-items-center gap-3">
                                    <div class="text-warning bg-warning bg-opacity-15 p-2.5 rounded-3 border border-warning border-opacity-25">
                                        <i data-lucide="hash" style="width: 20px; height: 20px;"></i>
                                    </div>
                                    <div>
                                        <div class="info-label">Identificador único</div>
                                        <div class="info-value text-warning">CROMO-#@Model.Id</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="info-box d-flex align-items-center gap-3">
                                    <div class="text-info bg-info bg-opacity-15 p-2.5 rounded-3 border border-info border-opacity-25">
                                        <i data-lucide="book-open" style="width: 20px; height: 20px;"></i>
                                    </div>
                                    <div class="text-truncate">
                                        <div class="info-label">Álbum Registrado</div>
                                        <div class="info-value text-truncate" style="color: #38bdf8;">
                                            @(Model.Album?.Nombre ?? $"Álbum ID: {Model.AlbumId}")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 d-flex flex-wrap gap-3">
                            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-edit-action px-4 py-2.5 rounded-3 d-inline-flex align-items-center gap-2 shadow"
                               data-ajax="true">
                                <i data-lucide="pencil" style="width: 16px; height: 16px;"></i> Editar Datos del Cromo
                            </a>
                            <a asp-action="Index" class="btn btn-outline-light px-4 py-2.5 rounded-3 d-inline-flex align-items-center gap-2 border-secondary opacity-90"
                               data-ajax="true">
                                <i data-lucide="layout-grid" style="width: 16px; height: 16px;"></i> Regresar al Catálogo
                            </a>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>