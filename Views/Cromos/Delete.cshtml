@model albumMundial.Models.Cromo

@{
    ViewData["Title"] = "Eliminar Cromo";
}

<style>
    body {
        background-color: #f4f6f9;
        color: #1e293b;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .card-delete-panel {
        border: 1px solid #fee2e2; /* Borde rojo suave */
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(239, 68, 68, 0.05);
        background-color: #ffffff;
        overflow: hidden;
    }

    /* Contenedor del Cromo a Eliminar */
    .cromo-delete-container {
        border: 1px solid #e2e8f0;
        background-color: #f8fafc;
        border-radius: 14px;
        width: 100%;
        max-width: 260px;
        aspect-ratio: 3 / 4;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
        opacity: 0.85; /* Sutil opacidad por estar en modo eliminación */
    }

    .cromo-delete-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        background-color: #edf2f7;
    }

    .badge-delete-number {
        position: absolute;
        top: 14px;
        left: 14px;
        background-color: #0f172a;
        color: #ffffff;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.75rem;
        z-index: 10;
    }

    /* Ficha resumida de datos */
    .info-label {
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.8px;
        margin-bottom: 1px;
    }

    .info-value {
        font-size: 1.05rem;
        font-weight: 600;
        color: #0f172a;
    }

    .info-box-delete {
        background-color: #fff5f5; /* Fondo rojizo muy sutil */
        border: 1px solid #fde8e8;
        border-radius: 12px;
        padding: 10px 14px;
    }

    /* Botón de eliminación destructiva masiva */
    .btn-danger-custom {
        background-color: #ef4444;
        color: white;
        font-weight: 600;
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        transition: all 0.2s;
    }

        .btn-danger-custom:hover {
            background-color: #dc2626;
            color: white;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);
        }

    .link-back {
        color: #64748b;
        font-weight: 600;
        transition: color 0.2s;
    }

        .link-back:hover {
            color: #00af50;
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 mb-4 p-3 shadow-sm" role="alert">
                <i data-lucide="alert-triangle" style="width: 24px; height: 24px;" class="flex-shrink-0"></i>
                <div>
                    <h5 class="alert-heading fw-bold m-0" style="font-size: 1.05rem;">¿Confirmas que deseas eliminar este registro?</h5>
                    <p class="m-0 small text-danger-emphasis">Esta acción es permanente y removerá por completo el cromo del sistema de inventario.</p>
                </div>
            </div>

            <div class="card card-delete-panel p-4 p-sm-5">
                <div class="row g-4 align-items-center">

                    @* SECCIÓN IZQUIERDA: FOTO DEL CROMO *@
                    <div class="col-md-4 d-flex justify-content-center">
                        <div class="cromo-delete-container">
                            <span class="badge-delete-number">N° @Model.NumeroCromo</span>

                            @if (!string.IsNullOrEmpty(Model.FotoUrl))
                            {
                                <img src="@Model.FotoUrl" class="cromo-delete-img" alt="Cromo" />
                            }
                            else
                            {
                                <i data-lucide="user" style="width: 48px; height: 48px;" class="text-muted opacity-25"></i>
                            }
                        </div>
                    </div>

                    @* SECCIÓN DERECHA: DATOS CLAVE Y FORMULARIO POST *@
                    <div class="col-md-8">
                        <div class="mb-3">
                            <span class="badge bg-secondary-subtle text-secondary px-2 py-1 rounded fw-bold text-uppercase mb-1" style="font-size: 0.65rem;">
                                Edición @Model.Edicion
                            </span>
                            <h3 class="fw-bold text-dark m-0">
                                @(Model.Jugador?.Nombre ?? "Crack Desconocido")
                            </h3>
                            <p class="text-muted small mb-0">Asociado al álbum: @(Model.Album?.Nombre ?? "Sin Asignar")</p>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col-sm-6">
                                <div class="info-box-delete d-flex align-items-center gap-2">
                                    <i data-lucide="dollar-sign" style="width: 18px; height: 18px;" class="text-danger"></i>
                                    <div>
                                        <div class="info-label">Valor de Mercado</div>
                                        <div class="info-value text-danger" style="font-size: 1rem;">$@string.Format("{0:N2}", Model.ValorMercado)</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted opacity-25 mb-4" />

                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />

                            <div class="d-flex flex-wrap align-items-center gap-3">
                                <button type="submit" class="btn btn-danger-custom d-inline-flex align-items-center gap-2">
                                    <i data-lucide="trash-2" style="width: 18px; height: 18px;"></i> Eliminar Definitivamente
                                </button>

                                <a asp-action="Index" class="text-decoration-none link-back small d-inline-flex align-items-center gap-1">
                                    Cancelar y Volver
                                </a>
                            </div>
                        </form>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>