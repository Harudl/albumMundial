@model albumMundial.Models.Jugador

@{
    ViewData["Title"] = "Eliminar Jugador";
}
<style>
    :root {
        --card-bg: rgba(22, 24, 31, 0.85);
        --border-color: rgba(38, 41, 54, 0.7);
        --accent-yellow: #ffc107;
        --text-secondary: #cbd5e1;
    }

    body {
        background: linear-gradient( 180deg, rgba(13,14,18,0.4) 0%, rgba(13,14,18,0.9) 100% ), url('/images/home_imagen.png') no-repeat center center fixed;
        background-size: cover;
    }

    .card-dashboard-dark {
        border: 1px solid var(--border-color);
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        background-color: var(--card-bg);
        backdrop-filter: blur(12px);
    }

    .form-label {
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: .8px;
    }

    .form-control-dark {
        background-color: rgba(13,14,18,0.6) !important;
        border: 1px solid var(--border-color) !important;
        color: #fff !important;
        border-radius: 8px;
        padding: 10px 14px;
    }

        .form-control-dark:focus {
            background-color: rgba(13,14,18,0.8) !important;
            border-color: var(--accent-yellow) !important;
            box-shadow: 0 0 0 3px rgba(255,193,7,.2) !important;
            color: white !important;
        }

    .preview-container {
        width: 100%;
        max-width: 220px;
        aspect-ratio: 3/4;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-color);
        background-color: rgba(10,11,14,.6);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .preview-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .file-dropzone-dark {
        position: relative;
        border: 2px dashed rgba(255,255,255,.2);
        background-color: rgba(13,14,18,.4);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: all .3s ease;
        cursor: pointer;
    }

        .file-dropzone-dark:hover {
            border-color: var(--accent-yellow);
            background-color: rgba(255,193,7,.05);
        }

        .file-dropzone-dark input[type=file] {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

    .btn-action-yellow {
        background-color: var(--accent-yellow);
        color: #000;
        font-weight: 700;
        text-transform: uppercase;
        border: none;
        border-radius: 8px;
        padding: 12px;
    }

        .btn-action-yellow:hover {
            background-color: #e0a800;
            color: #000;
        }

    .link-back {
        color: var(--text-secondary);
        font-weight: 600;
    }

        .link-back:hover {
            color: var(--accent-yellow);
        }

    .form-check-input {
        transform: scale(1.3);
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="alert alert-danger-dark d-flex align-items-center gap-3 rounded-3 mb-4 p-3 shadow-lg" role="alert">
                <i data-lucide="alert-triangle"
                   style="width:28px;height:28px;color:#f87171;"
                   class="flex-shrink-0"></i>

                <div>
                    <h5 class="alert-heading fw-bold m-0">
                        ¿Confirmas que deseas eliminar este jugador?
                    </h5>

                    <p class="m-0 small opacity-90">
                        Esta acción es permanente y removerá al jugador del sistema.
                    </p>
                </div>
            </div>

            <div class="card card-delete-panel p-4 p-sm-5">

                <div class="row g-4 align-items-center">

                    <div class="col-md-4 d-flex justify-content-center">

                        <div class="cromo-delete-container">

                            <span class="badge-delete-number">
                                #@Model.NumeroCamiseta
                            </span>

                            @if (!string.IsNullOrEmpty(Model.FotoUrl))
                            {
                                <img src="@Model.FotoUrl"
                                     class="cromo-delete-img"
                                     alt="@Model.Nombre" />
                            }
                            else
                            {
                                <i data-lucide="user-round"
                                   style="width:64px;height:64px;"
                                   class="text-white opacity-25"></i>
                            }

                        </div>

                    </div>

                    <div class="col-md-8">

                        <div class="mb-3">

                            <span class="badge text-uppercase px-2 py-1 rounded fw-bold mb-2"
                                  style="background-color:rgba(255,255,255,0.1);
                                color:#e2e8f0;
                                border:1px solid rgba(255,255,255,0.15);
                                font-size:0.65rem;">
                                @Model.Posicion
                            </span>

                            <h2 class="fw-extrabold text-white m-0">
                                @Model.Nombre
                            </h2>

                            <p class="small mb-0 mt-1 text-secondary">
                                <i data-lucide="shield"
                                   class="d-inline-block text-info me-1"
                                   style="width:14px;height:14px;"></i>

                                Equipo:
                                <span class="text-white fw-semibold">
                                    @(Model.Equipo?.Nombre ?? "Sin equipo")
                                </span>
                            </p>

                        </div>

                        <div class="row g-2 mb-4">

                            <div class="col-sm-6">
                                <div class="info-box-delete">

                                    <div class="info-label">
                                        Número de Camiseta
                                    </div>

                                    <div class="info-value text-warning">
                                        #@Model.NumeroCamiseta
                                    </div>

                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="info-box-delete">

                                    <div class="info-label">
                                        Fecha de Nacimiento
                                    </div>

                                    <div class="info-value">
                                        @Model.FechaNacimiento.ToString("dd/MM/yyyy")
                                    </div>

                                </div>
                            </div>

                        </div>

                        @if (Model.Cromo != null)
                        {
                            <div class="alert alert-warning mb-4">
                                Este jugador tiene un cromo asociado.
                            </div>
                        }

                        <hr class="border-secondary opacity-25 mb-4" />

                        <form asp-action="Delete">

                            <input type="hidden" asp-for="Id" />

                            <div class="d-flex flex-wrap align-items-center gap-4">

                                <button type="submit"
                                        class="btn btn-danger-custom d-inline-flex align-items-center gap-2 shadow">

                                    <i data-lucide="trash-2"
                                       style="width:18px;height:18px;"></i>

                                    Eliminar Definitivamente

                                </button>

                                <a asp-action="Index"
                                   class="text-decoration-none link-back small d-inline-flex align-items-center gap-1">

                                    Cancelar y Volver

                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>
    </div>
</div>