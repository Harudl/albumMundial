@model IEnumerable<albumMundial.Models.Jugador>

@{
    ViewData["Title"] = "Jugadores por Equipo";
}

<style>
    :root {
        --card-bg: rgba(22, 24, 31, 0.85);
        --border-color: rgba(38, 41, 54, 0.7);
        --accent-yellow: #ffc107;
        --text-secondary: #cbd5e1;
    }

    body {
        background: linear-gradient( 180deg, rgba(13, 14, 18, 0.4) 0%, rgba(13, 14, 18, 0.9) 100% ), url('/images/home_imagen.png') no-repeat center center fixed;
        background-size: cover;
    }

    .glass-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        backdrop-filter: blur(12px);
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.5);
    }

    .player-card {
        background-color: rgba(13,14,18,0.65);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        transition: all .25s ease;
    }

        .player-card:hover {
            transform: translateY(-4px);
            border-color: rgba(255,193,7,.4);
            box-shadow: 0 10px 25px rgba(0,0,0,.35);
        }

    .player-avatar {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: rgba(255,193,7,.15);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .info-label {
        color: var(--text-secondary);
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .8px;
        font-weight: 700;
    }

    .info-value {
        color: white;
        font-weight: 700;
    }

    .btn-details {
        background-color: var(--accent-yellow);
        color: black;
        border: none;
        font-weight: 700;
    }

        .btn-details:hover {
            background-color: #e0a800;
            color: black;
        }

    .link-back {
        color: var(--text-secondary);
        text-decoration: none;
        font-weight: 600;
    }

        .link-back:hover {
            color: var(--accent-yellow);
        }

    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: var(--text-secondary);
    }
</style>

<div class="container py-5">

    ```
    <div class="mb-4">
        <a asp-controller="Equipos"
           asp-action="Details"
           asp-route-id="@ViewData["EquipoId"]"
           class="link-back d-inline-flex align-items-center gap-2">

            <i data-lucide="arrow-left" style="width:16px;height:16px;"></i>
            Regresar al Equipo
        </a>
    </div>

    <div class="glass-card p-4 p-md-5">

        <div class="text-center mb-5">
            <h1 class="fw-bold text-white mb-2">
                Plantilla de @ViewData["EquipoNombre"]
            </h1>

            <p class="mb-0" style="color: var(--text-secondary);">
                Jugadores registrados para este equipo.
            </p>
        </div>

        @if (Model.Any())
        {
            <div class="row g-4">

                @foreach (var item in Model)
                {
                    <div class="col-lg-6">

                        <div class="player-card p-3 h-100">

                            <div class="d-flex align-items-center gap-3">

                                <div class="player-avatar">
                                    <i data-lucide="user"
                                       class="text-warning"
                                       style="width:32px;height:32px;">
                                    </i>
                                </div>

                                <div class="flex-grow-1">

                                    <h5 class="text-white fw-bold mb-1">
                                        @item.Nombre
                                    </h5>

                                    <div class="small text-secondary">
                                        @item.Equipo?.Nombre
                                    </div>

                                </div>

                            </div>

                            <hr class="border-secondary opacity-25">

                            <div class="row g-3">

                                <div class="col-6">
                                    <div class="info-label">
                                        Posición
                                    </div>

                                    <div class="info-value">
                                        @item.Posicion
                                    </div>
                                </div>

                                <div class="col-6">
                                    <div class="info-label">
                                        Dorsal
                                    </div>

                                    <div class="info-value">
                                        #@item.NumeroCamiseta
                                    </div>
                                </div>

                            </div>

                            <div class="mt-4">

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-details w-100">

                                    Ver Perfil del Jugador
                                </a>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }
        else
        {
            <div class="empty-state">

                <i data-lucide="users"
                   style="width:60px;height:60px;"
                   class="mb-3">
                </i>

                <h4>No hay jugadores registrados</h4>

                <p class="mb-0">
                    Este equipo aún no tiene jugadores asociados.
                </p>

            </div>
        }

    </div>
    ```

</div>
