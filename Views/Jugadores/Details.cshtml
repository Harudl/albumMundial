@model albumMundial.Models.Jugador

@{
    ViewData["Title"] = "Detalles del Jugador";
}
<style>
    :root {
        --card-bg: rgba(22, 24, 31, 0.85);
        --border-color: rgba(38, 41, 54, 0.7);
        --accent-yellow: #ffc107;
        --text-secondary: #cbd5e1;
    }

    body {
        background: linear-gradient( 180deg, rgba(13,14,18,0.4) 0%, rgba(13,14,18,0.9) 100% ), url('/images/home_imagen.png') no-repeat center center fixed;
        background-size: cover;
    }

    .card-dashboard-dark {
        border: 1px solid var(--border-color);
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        background-color: var(--card-bg);
        backdrop-filter: blur(12px);
    }

    .form-label {
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: .8px;
    }

    .form-control-dark {
        background-color: rgba(13,14,18,0.6) !important;
        border: 1px solid var(--border-color) !important;
        color: #fff !important;
        border-radius: 8px;
        padding: 10px 14px;
    }

        .form-control-dark:focus {
            background-color: rgba(13,14,18,0.8) !important;
            border-color: var(--accent-yellow) !important;
            box-shadow: 0 0 0 3px rgba(255,193,7,.2) !important;
            color: white !important;
        }

    .preview-container {
        width: 100%;
        max-width: 220px;
        aspect-ratio: 3/4;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-color);
        background-color: rgba(10,11,14,.6);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .preview-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .file-dropzone-dark {
        position: relative;
        border: 2px dashed rgba(255,255,255,.2);
        background-color: rgba(13,14,18,.4);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: all .3s ease;
        cursor: pointer;
    }

        .file-dropzone-dark:hover {
            border-color: var(--accent-yellow);
            background-color: rgba(255,193,7,.05);
        }

        .file-dropzone-dark input[type=file] {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

    .btn-action-yellow {
        background-color: var(--accent-yellow);
        color: #000;
        font-weight: 700;
        text-transform: uppercase;
        border: none;
        border-radius: 8px;
        padding: 12px;
    }

        .btn-action-yellow:hover {
            background-color: #e0a800;
            color: #000;
        }

    .link-back {
        color: var(--text-secondary);
        font-weight: 600;
    }

        .link-back:hover {
            color: var(--accent-yellow);
        }

    .form-check-input {
        transform: scale(1.3);
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="mb-4">
                <a asp-action="Index"
                   class="text-decoration-none link-back small d-inline-flex align-items-center gap-2">
                    <i data-lucide="arrow-left" style="width:16px;height:16px;"></i>
                    Volver al Catálogo de Jugadores
                </a>
            </div>

            <div class="card card-details p-4 p-sm-5">

                <div class="row g-5 align-items-center">

                    <!-- FOTO DEL JUGADOR -->
                    <div class="col-md-5 d-flex justify-content-center">

                        <div class="cromo-view-container border-view-estandar">

                            <span class="badge-view-number">
                                #@Model.NumeroCamiseta
                            </span>

                            @if (!string.IsNullOrEmpty(Model.FotoUrl))
                            {
                                <img src="@Model.FotoUrl"
                                     class="cromo-view-img"
                                     alt="@Model.Nombre" />
                            }
                            else
                            {
                                <div class="text-center py-5 opacity-25">
                                    <i data-lucide="user"
                                       style="width:64px;height:64px;"
                                       class="text-white mb-2"></i>

                                    <p class="text-white small mb-0">
                                        Sin fotografía
                                    </p>
                                </div>
                            }

                        </div>

                    </div>

                    <!-- DATOS DEL JUGADOR -->
                    <div class="col-md-7">

                        <div class="mb-4">

                            <span class="badge text-uppercase px-3 py-2 rounded-pill mb-2 fw-bold"
                                  style="background-color:rgba(255,255,255,0.1);
                                color:#e2e8f0;
                                border:1px solid rgba(255,255,255,0.2);">
                                @Model.Posicion
                            </span>

                            <h1 class="fw-extrabold text-white m-0 mt-2">
                                @Model.Nombre
                            </h1>

                            <p class="small mt-1 text-secondary">
                                Perfil oficial registrado en el Álbum Mundial.
                            </p>

                        </div>

                        <hr class="border-secondary opacity-25 my-4" />

                        <div class="row g-3">

                            <div class="col-sm-6">
                                <div class="info-box">
                                    <div class="info-label">
                                        Equipo
                                    </div>

                                    <div class="info-value text-info">
                                        @(Model.Equipo?.Nombre ?? "Sin equipo")
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="info-box">
                                    <div class="info-label">
                                        Posición
                                    </div>

                                    <div class="info-value text-warning">
                                        @Model.Posicion
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="info-box">
                                    <div class="info-label">
                                        Número de Camiseta
                                    </div>

                                    <div class="info-value">
                                        #@Model.NumeroCamiseta
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="info-box">
                                    <div class="info-label">
                                        Fecha de Nacimiento
                                    </div>

                                    <div class="info-value">
                                        @Model.FechaNacimiento.ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="info-box">
                                    <div class="info-label">
                                        Estado del Cromo
                                    </div>

                                    <div class="info-value">
                                        @(Model.Cromo != null
                                            ? "Tiene cromo asignado"
                                            : "Sin cromo asignado")
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="mt-5 d-flex flex-wrap gap-3">

                            <a asp-action="Edit"
                               asp-route-id="@Model.Id"
                               class="btn btn-edit-action px-4 py-2 rounded-3 d-inline-flex align-items-center gap-2 shadow">

                                <i data-lucide="pencil"
                                   style="width:16px;height:16px;"></i>

                                Editar Jugador

                            </a>

                            <a asp-action="Index"
                               class="btn btn-outline-light px-4 py-2 rounded-3 d-inline-flex align-items-center gap-2 border-secondary">

                                <i data-lucide="users"
                                   style="width:16px;height:16px;"></i>

                                Regresar al Catálogo

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>
    </div>
</div>