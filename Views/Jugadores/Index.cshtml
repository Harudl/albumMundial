@using System.Linq
@model IEnumerable<albumMundial.Models.Jugador>

@{
    ViewData["Title"] = "Jugadores";
}

<div class="container mt-4">
    <div class="sports-widget">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div class="widget-title">
                <i data-lucide="users" class="text-warning" style="width:20px;height:20px;"></i>
                <span class="fs-5 text-white"
                      style="text-transform:none;letter-spacing:normal;font-weight:700;">
                    Catálogo de Jugadores
                </span>
            </div>

            <a asp-action="Create"
               class="btn btn-warning btn-sm fw-bold px-3 py-2 rounded-2 shadow">
                + Registrar Jugador
            </a>
        </div>

        <form asp-action="Index" method="get" class="row g-2 mb-4">
            <div class="col-md-7">
                <input type="text"
                       name="searchString"
                       value="@(ViewData["CurrentFilter"] as string ?? "")"
                       class="form-control form-dark-input"
                       placeholder="Buscar por nombre o equipo..." />
            </div>

            <div class="col-md-5 d-flex gap-2">
                <button type="submit"
                        class="btn btn-outline-light w-100 fw-semibold border-secondary">
                    <i data-lucide="search"
                       style="width:14px;height:14px;"
                       class="me-1"></i>
                    Buscar
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary w-100 opacity-75">
                    Limpiar
                </a>
            </div>
        </form>

        <hr class="border-secondary opacity-25 mb-4">

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            @foreach (var item in Model ?? Enumerable.Empty<albumMundial.Models.Jugador>())
            {
                <div class="col">
                    <div class="cromo-card h-100">

                        <div class="cromo-img-container">

                            @if (!string.IsNullOrEmpty(item.FotoUrl))
                            {
                                <img src="@item.FotoUrl"
                                     class="cromo-img"
                                     alt="@item.Nombre" />
                            }
                            else
                            {
                                <div class="text-center opacity-50">
                                    <i data-lucide="user-round"
                                       style="width:90px;height:90px;color:#ffc107;">
                                    </i>
                                </div>
                            }

                            <span class="badge-number">
                                #@item.NumeroCamiseta
                            </span>

                        </div>

                        <div class="card-body p-3">

                            <div class="d-flex justify-content-between align-items-center mb-2">

                                <span class="badge bg-warning text-dark fw-bold">
                                    @item.Posicion
                                </span>

                                @if (item.Cromo != null)
                                {
                                    <span class="badge bg-success">
                                        Tiene Cromo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Sin Cromo
                                    </span>
                                }

                            </div>

                            <h5 class="fw-bold text-white mb-2 text-truncate">
                                @item.Nombre
                            </h5>

                            <p class="mb-2 small text-info d-flex align-items-center gap-1">
                                <i data-lucide="shield"
                                   style="width:14px;height:14px;"></i>

                                @(item.Equipo?.Nombre ?? "Sin equipo")
                            </p>

                            <p class="mb-0 small text-white-50 d-flex align-items-center gap-1">
                                <i data-lucide="calendar"
                                   style="width:14px;height:14px;"></i>

                                @item.FechaNacimiento.ToString("dd/MM/yyyy")
                            </p>

                        </div>

                        <div class="btn-action-panel p-2 d-flex justify-content-around align-items-center">

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="action-icon edit-btn text-decoration-none small d-flex align-items-center gap-1">

                                <i data-lucide="pencil"
                                   style="width:15px;height:15px;"></i>

                                <span style="font-size:0.75rem;">
                                    Editar
                                </span>
                            </a>

                            <div class="text-white-50 opacity-25">|</div>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="action-icon text-decoration-none small d-flex align-items-center gap-1">

                                <i data-lucide="eye"
                                   style="width:15px;height:15px;"></i>

                                <span style="font-size:0.75rem;">
                                    Ver
                                </span>
                            </a>

                            <div class="text-white-50 opacity-25">|</div>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="action-icon delete-btn text-decoration-none small d-flex align-items-center gap-1">

                                <i data-lucide="trash-2"
                                   style="width:15px;height:15px;"></i>

                                <span style="font-size:0.75rem;">
                                    Borrar
                                </span>
                            </a>

                        </div>

                    </div>
                </div>
            }

        </div>

    </div>
</div>