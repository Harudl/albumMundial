@model albumMundial.Models.Jugador

@{
    ViewData["Title"] = "Crear Jugador";
}


<style>
    body {
        background-color: #f4f6f9; /* Fondo gris claro, muy limpio */
        color: #1e293b; /* Texto oscuro para excelente contraste */
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Tarjeta principal en modo claro */
    .card-dashboard-light {
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(30, 41, 59, 0.05);
        background-color: #ffffff; /* Tarjeta totalmente blanca */
    }

    .header-dashboard {
        padding: 30px 20px 10px 20px;
    }

    .form-label {
        font-weight: 700;
        color: #475569; /* Gris oscuro para etiquetas legibles */
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.8px;
    }

    /* Campos de texto y selectores limpios */
    .form-control-light {
        background-color: #f8fafc !important; /* Fondo sutilmente gris para los inputs */
        border: 1px solid #cbd5e1 !important;
        color: #0f172a !important;
        border-radius: 8px;
        padding: 10px 14px;
        transition: all 0.2s ease;
    }

        .form-control-light:focus {
            background-color: #ffffff !important;
            border-color: #00af50 !important; /* Enfoque en verde césped */
            box-shadow: 0 0 0 3px rgba(0, 175, 80, 0.15) !important;
        }

        .form-control-light::placeholder {
            color: #94a3b8;
        }

    /* Zona de carga de archivos en modo claro */
    .file-dropzone-light {
        position: relative;
        border: 2px dashed #cbd5e1;
        background-color: #f8fafc;
        border-radius: 12px;
        padding: 25px;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .file-dropzone-light:hover {
            background-color: #f0fdf4; /* Destello verde suave al pasar el mouse */
            border-color: #00af50;
        }

        .file-dropzone-light input[type="file"] {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

    .dropzone-icon {
        font-size: 2rem;
        color: #00af50;
    }

    /* Botón de acción principal: Verde Estadio */
    .btn-action-green {
        background-color: #00af50;
        color: #ffffff;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: none;
        border-radius: 8px;
        padding: 12px;
        transition: all 0.3s ease;
    }

        .btn-action-green:hover {
            background-color: #009645;
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(0, 175, 80, 0.2);
        }

    /* Enlace de regreso */
    .link-back {
        color: #64748b;
        font-weight: 600;
        transition: color 0.2s;
    }

        .link-back:hover {
            color: #00af50;
        }
</style>


<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">

            ```
            <div class="mb-4">
                <a asp-action="Index"
                   class="text-decoration-none link-back small">
                    ← Volver a Jugadores
                </a>
            </div>

            <div class="card card-dashboard-dark">

                <div class="p-4 text-center">
                    <h3 class="fw-bold text-white mb-1">
                        Crear Jugador
                    </h3>

                    <p class="small mb-0"
                       style="color: var(--text-secondary);">
                        Registra una nueva estrella para el álbum.
                    </p>

                    <hr class="border-secondary opacity-25 mt-3 mb-0" />
                </div>

                <div class="card-body px-4 pb-5 pt-0">

                    <form asp-action="Create"
                          enctype="multipart/form-data">

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger small">
                        </div>

                        <div class="row g-4">

                            <div class="col-md-4 d-flex flex-column align-items-center">

                                <label class="form-label text-white-50 mb-2">
                                    Fotografía
                                </label>

                                <div class="preview-container mb-3">
                                    <img id="img-preview"
                                         src=""
                                         style="display:none;" />

                                    <i id="placeholder-icon"
                                       data-lucide="user"
                                       class="text-white opacity-25"
                                       style="width:64px;height:64px;">
                                    </i>
                                </div>

                                <div class="file-dropzone-dark w-100">
                                    <i data-lucide="upload"
                                       class="text-warning mb-2"></i>

                                    <h6 class="text-white fw-bold">
                                        Subir Imagen
                                    </h6>

                                    <p class="small mb-0"
                                       style="color: var(--text-secondary);">
                                        JPG o PNG
                                    </p>

                                    <input type="file"
                                           id="imagenJugador"
                                           name="imagenJugador"
                                           accept="image/*" />
                                </div>

                                <div id="file-name-preview"
                                     class="text-warning small mt-2 text-center">
                                </div>

                            </div>

                            <div class="col-md-8">

                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label"></label>
                                    <input asp-for="Nombre" class="form-control form-control-dark" />
                                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Posicion" class="form-label"></label>
                                    <input asp-for="Posicion" class="form-control form-control-dark" />
                                    <span asp-validation-for="Posicion" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="NumeroCamiseta" class="form-label"></label>
                                        <input asp-for="NumeroCamiseta" class="form-control form-control-dark" />
                                        <span asp-validation-for="NumeroCamiseta" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label asp-for="FechaNacimiento" class="form-label"></label>
                                        <input asp-for="FechaNacimiento"
                                               type="date"
                                               class="form-control form-control-dark" />
                                        <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="EquipoId" class="form-label">
                                        Equipo
                                    </label>

                                    <select asp-for="EquipoId"
                                            asp-items="ViewBag.EquipoId"
                                            class="form-select form-control-dark">
                                        <option value="">
                                            -- Seleccione un equipo --
                                        </option>
                                    </select>

                                    <span asp-validation-for="EquipoId"
                                          class="text-danger small">
                                    </span>
                                </div>

                                <div class="d-grid">
                                    <button type="submit"
                                            class="btn btn-action-yellow">
                                        Crear Jugador
                                    </button>
                                </div>

                            </div>

                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
    ```

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    ```
    <script>
        document.getElementById('imagenJugador')
            .addEventListener('change', function(e){

            let file = e.target.files[0];

            let previewText =
                document.getElementById('file-name-preview');

            let img =
                document.getElementById('img-preview');

            let placeholder =
                document.getElementById('placeholder-icon');

            if(file){

                previewText.innerHTML =
                    "✓ Imagen seleccionada: " + file.name;

                let reader = new FileReader();

                reader.onload = function(ev){
                    img.src = ev.target.result;
                    img.style.display = "block";
                    placeholder.style.display = "none";
                };

                reader.readAsDataURL(file);
            }
        });
    </script>
    ```

}
